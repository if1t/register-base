{
  "name": "ngx-register-base",
  "version": "1.3.0",
  "scripts": {
    "build": "tsc -p tsconfig.schematics.json",
    "postbuild": "copyfiles schematics/*/schema.json schematics/*/files/** schematics/collection.json schematics/migration-collection.json ../../dist/ngx-register-base/"
  },
  "schematics": "./schematics/collection.json",
  "ng-update": {
    "migrations": "./schematics/migration-collection.json"
  },
  "exports": {
    "./icons/*": "./icons/*",
    "./styles/*": "./styles/*"
  },
  "peerDependencies": {
    "@angular/cdk": "^18.2.0",
    "@angular/common": "^18.2.0",
    "@angular/core": "^18.2.0",
    "@apollo/client": "^3.13.5",
    "@ngrx/component-store": "^18.1.1",
    "@taiga-ui/addon-table": "4.48.0",
    "@taiga-ui/core": "4.48.0",
    "@taiga-ui/kit": "4.48.0",
    "@taiga-ui/legacy": "4.48.0",
    "apollo-angular": "^10.0.3",
    "date-fns": "^4.1.0",
    "graphql": "^16.10.0",
    "lodash": "^4.17.21",
    "moment-timezone": "^0.5.48",
    "rxjs": "~7.8.0"
  },
  "dependencies": {
    "tslib": "^2.3.0"
  },
  "devDependencies": {
    "copyfiles": "file:../../node_modules/copyfiles",
    "typescript": "file:../../node_modules/typescript"
  },
  "sideEffects": false
}
